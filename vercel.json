{
  "regions": ["iad1"],
  "functions": {
    "api/app.js":        { "regions": ["iad1"], "maxDuration": 5  },
    "api/version.js":    { "regions": ["iad1"], "maxDuration": 5  },
    "api/rpc.js":        { "regions": ["iad1"], "maxDuration": 15 },
    "api/balance.js":    { "regions": ["iad1"], "maxDuration": 10 },
    "api/settle.js":     { "regions": ["iad1"], "maxDuration": 60 },
    "api/join.js":       { "regions": ["iad1"], "maxDuration": 20 },
    "api/verify-entry.js":  { "regions": ["iad1"], "maxDuration": 5  },
    "api/check-wager.js":   { "regions": ["iad1"], "maxDuration": 5  },
    "api/leaderboard.js":   { "regions": ["iad1"], "maxDuration": 10 },
    "api/ably-token.js": { "regions": ["iad1"], "maxDuration": 5  },
    "api/price.js":      { "regions": ["iad1"], "maxDuration": 10 },
    "api/privy.js":      { "regions": ["iad1"], "maxDuration": 10 },
    "api/wallet.js":     { "regions": ["iad1"], "maxDuration": 15 }
  },
  "redirects": [],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/api/app" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control",             "value": "no-cache, no-store, max-age=0, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control",  "value": "no-store" },
        { "key": "Pragma",                    "value": "no-cache" },
        { "key": "Expires",                   "value": "0" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
